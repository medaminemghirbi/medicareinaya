rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // Products — public read, admin write
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories — public read, admin write
    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog articles — public read, admin write
    match /blog_articles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Wiki pages — public read, admin write
    match /wiki_pages/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Contact requests — anyone can submit, admin manages
    match /contact_requests/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Notifications — logged-in users read, admin write
    match /notifications/{id} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Orders — user sees own, admin sees all
    match /orders/{id} {
      allow create: if isLoggedIn();
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Users — own profile or admin
    match /users/{userId} {
      allow read: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isLoggedIn() && request.auth.uid == userId;
      allow update: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
